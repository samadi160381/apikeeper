# Server
PORT=3000

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/api_keys

# Redis (used for rate limiting + live usage counters)
REDIS_URL=redis://localhost:6379

# Secret used to sign/verify admin dashboard requests (replace with real auth in prod)
ADMIN_TOKEN=change-me-to-a-long-random-string

# Stripe (optional - only needed if you want metered billing sync)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_METER_EVENT_NAME=api_requests
